{
  "manifest_version": 3,
  "name": "levels.fyi location & sort defaults",
  "version": "2.0.0",
  "description": "Auto-redirects levels.fyi salary pages to your preferred location, sort order, and page size. Configurable.",
  "icons": {
    "16": "icons/icon-16.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["declarativeNetRequest", "storage", "webNavigation"],
  "host_permissions": ["*://*.levels.fyi/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "levels.fyi defaults",
    "default_popup": "options.html",
    "default_icon": {
      "16": "icons/icon-16.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  }
}
